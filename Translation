#include <iostream>
using namespace std;

int main() {

    string s, t;
    cin >> s >> t;

    int n = s.size();

    bool ok = true;

    for(int i = 0; i < n; i++) {

        if(s[i] != t[n - i - 1]) {
            ok = false;
            break;
        }
    }

    if(ok) {
        cout << "YES";
    }
    else {
        cout << "NO";
    }

    return 0;
}
