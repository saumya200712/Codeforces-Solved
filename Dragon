#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int main() {

    int s, n;
    cin >> s >> n;

    vector<pair<int,int>> dragon(n);

    for(int i = 0; i < n; i++) {
        cin >> dragon[i].first >> dragon[i].second;
    }

    // sort by dragon strength
    sort(dragon.begin(), dragon.end());

    for(int i = 0; i < n; i++) {

        int x = dragon[i].first;
        int y = dragon[i].second;

        // cannot defeat
        if(s <= x) {
            cout << "NO";
            return 0;
        }

        // gain bonus
        s += y;
    }

    cout << "YES";

    return 0;
}
